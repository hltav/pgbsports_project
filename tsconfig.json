{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "strict": true,
    "sourceMap": true,
    "outDir": "./dist/app",
    "baseUrl": "./",
    "types": ["node", "jest", "multer", "express"],
    "typeRoots": ["./node_modules/@types", "./@types"],
    "paths": {
      "@lib/*": ["src/lib/*"],
      "@app/*": ["src/app/*"],
      "@config/*": ["src/config/*"],
      "@modules/*": ["src/modules/*"],
      "@/*": ["src/*"]
    },
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false
  }
}
