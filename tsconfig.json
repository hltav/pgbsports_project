{
  "compilerOptions": {
    "module": "commonjs",                
    "declaration": true,                 
    "removeComments": true,
    "emitDecoratorMetadata": true,      
    "experimentalDecorators": true,     
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",                  
    "strict": true,
    "sourceMap": true,
    "outDir": "./dist",                 
    "baseUrl": "./",
    "types": ["node", "jest", "multer", "express"],
    "typeRoots": ["./node_modules/@types", "./@types"],
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false
  },
  "exclude": [
    "node_modules",
    "test",
    "dist",
    "**/*.spec.ts",
    "dist/**/*",
    "libs/**/*.ts",
    "modules/**/*.ts"
  ]  
}
