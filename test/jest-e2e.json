{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/libs/database$": "<rootDir>/src/libs/database/src/index.ts",
    "^src/libs/common/src$": "<rootDir>/src/libs/common/index.ts",
    "^src/(.*)$": "<rootDir>/src/$1"
  }
}