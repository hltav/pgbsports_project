{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": "tsc",
    "assets": [
      {
        "include": "libs/services/mailer/templates/**/*.hbs",
        "outDir": "dist/libs/services/mailer/templates",
        "watchAssets": true
      }
    ],
    "watchAssets": true,
    "tsConfigPath": "tsconfig.build.json"
  }
}