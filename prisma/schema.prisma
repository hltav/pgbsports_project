// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum pare tipo de usuário
enum Role {
  USER
  TEST_USER
  ADMIN
}

// Enum pare tipo do evento
enum EventType {
  SINGLE
  MULTIPLE
  LIVE
}

// Enum para resultado do evento
enum Result {
  pending
  win
  lose
  draw
  returned
  void
}

//Dados iniciais de usuário
model User {
  id           Int         @id @default(autoincrement())
  firstname    String
  lastname     String
  nickname     String      @unique
  email        String      @unique
  password     String
  role         Role        @default(USER)
  clientData   ClientData?
  refreshToken String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  Bankroll     Bankroll[]
  Event        Event[]
}

//Dados de Cliente
model ClientData {
  id        Int      @id @default(autoincrement())
  gender    String
  cpf       String   @unique
  phone     String   @default("")
  image     String
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  address   Address?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//Endereço do Cliente
model Address {
  id           Int         @id @default(autoincrement())
  direction    String?
  houseNumber  Int?
  neighborhood String?
  city         String?
  state        String?
  country      String?
  clientDataId Int         @unique
  clientData   ClientData  @relation(fields: [clientDataId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

//Dados da Banca 
model Bankroll {
  id        Int       @id @default(autoincrement())
  name      String
  balance   Float
  unidValue Float
  events    Event[]
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

//Dados do Evento esportivo
model Event {
  id        Int        @id @default(autoincrement())
  bankId    Int
  bank      Bankroll   @relation(fields: [bankId], references: [id], onDelete: Cascade)
  eventType EventType
  event     String
  market    String
  amount    Float
  result    Result     @default(pending)
  userId    Int
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId, eventType])
}
