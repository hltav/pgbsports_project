// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int         @id @default(autoincrement())
  firstname    String
  lastname     String
  nickname     String      @unique
  email        String      @unique
  password     String
  role         Role        @default(USER)
  clientData   ClientData? // Relação um-para-um com ClientData (opcional)
  refreshToken String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

enum Role {
  USER
  ADMIN
}

model ClientData {
  id        Int      @id @default(autoincrement())
  gender    String
  cpf       String   @unique
  image     String
  userId    Int      @unique // Chave estrangeira para User (única)
  user      User     @relation(fields: [userId], references: [id]) // Relação com User
  address   Address? // Relação um-para-um com Address (opcional)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Address {
  id           Int         @id @default(autoincrement())
  direction    String
  houseNumber  Int
  neighborhood String
  city         String
  state        String
  country      String // Corrigido para minúsculo (boas práticas)
  clientDataId Int         @unique // Chave estrangeira para ClientData (única)
  clientData   ClientData? @relation(fields: [clientDataId], references: [id]) // Relação com ClientData
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Bankroll {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  balance Float
  events  Event[] // Relação com Event
}

model Event {
  id        Int      @id @default(autoincrement())
  bankId    Int
  bank      Bankroll @relation(fields: [bankId], references: [id]) // Relação com Bankroll
  eventType String
  event     String
  market    String
  amount    Float
  result    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
