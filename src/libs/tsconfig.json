// src/libs/tsconfig.json
{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "declaration": true,
    "outDir": "../../dist/libs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "*": ["*", "../../../node_modules/*"]
    }
  },
  "include": [
    "**/*.ts",
    "../modules/auth/dto/auth.dto.ts",
    "../modules/auth/dto/login.dto.ts",
    "../modules/auth/dto/refresh-token.dto.ts",
    "../modules/auth/interface/jwt-payload.interface.ts"
  ],
  "exclude": ["../../node_modules", "../../test"]
}
